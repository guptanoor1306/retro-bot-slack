# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Required only for Socket Mode (recommended for local dev)
SLACK_APP_TOKEN=xapp-your-app-token

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEET_ID=your-spreadsheet-id

# Slack channel for retro threads (#video-retros)
RETRO_CHANNEL_ID=C0123456789

# Use socket mode (true) or HTTP (false)
USE_SOCKET_MODE=true

# Railway: set to "insights" on the insights service only (bot service omits this)
# APP_MODE=insights

# Server port when not using socket mode
PORT=3000

# Insights dashboard (week-on-week learning)
INSIGHTS_PORT=4000
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Premier (Zero1 Premier)
PREMIER_API_URL=https://premier-backend.zero1premier.com
PREMIER_EMAIL=admin.premier@learnapp.com
PREMIER_PASSWORD=
# Login: POST /auth/admin/login → 201 + bearer token (auto-refreshed every ~3.5h)
PREMIER_LOGIN_PATH=/auth/admin/login
PREMIER_TOKEN_TTL_HOURS=3.5
# Optional: static token instead of email/password login
# PREMIER_BEARER_TOKEN=
